# Copy to .env and fill in.

# Discord bot token. The bot must be added to the server with the
# "View Channel" and "Read Message History" permissions on the poker channel.
DISCORD_TOKEN=

# ID of the Discord channel that contains the session threads.
# Enable Developer Mode in Discord, right-click the channel, "Copy Channel ID".
DISCORD_CHANNEL_ID=

# Base URL of the poker tracker API (no trailing slash).
TRACKER_API_BASE=https://srv1346724.hstgr.cloud/api

# Anthropic API key for vision OCR of ledger screenshots.
ANTHROPIC_API_KEY=

# Optional: Anthropic model to use for vision parsing.
# Default: claude-haiku-4-5 (cheap, accurate enough for clean tabular screenshots).
ANTHROPIC_MODEL=claude-haiku-4-5
