# Copy to .env and fill in.

# Discord bot token (same one used by the backfill scripts).
DISCORD_TOKEN=

# ID of the Discord text channel under which session threads live.
DISCORD_CHANNEL_ID=

# Optional: role ID to @mention on each results post, so everyone in the role
# is pulled into the results thread. Right-click the role with Developer Mode
# on → Copy ID. The bot needs permission to mention this role. Leave blank to
# disable mentions.
DISCORD_POKER_ROLE_ID=

# Base URL of the poker tracker API.
TRACKER_API_BASE=https://srv1346724.hstgr.cloud/api

# Where the tracker can reach this bot's announcement endpoint.
# In production both run on the same VPS so localhost is fine.
# Avoid ports on Node's undici "bad ports" list (6000 = X11, 6665-6669 = IRC, etc.)
BOT_HTTP_PORT=6300

# Public base URL of the tracker UI (used in "please map aliases" messages).
TRACKER_UI_BASE=https://srv1346724.hstgr.cloud

# Gemini API key (vision OCR of ledger screenshots).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Chips-to-dollars conversion for PokerNow CSV imports. Default 100 means
# 100 chips = $1 (the most common home-game stake). Set to 1 if your game
# actually plays in dollar units.
POKERNOW_CHIP_DIVISOR=100
